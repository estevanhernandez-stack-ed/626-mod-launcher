<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="ModManager.App.Tools.ToolConfigureDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Configure tool"
    PrimaryButtonText="Save"
    SecondaryButtonText="Uninstall"
    CloseButtonText="Cancel"
    DefaultButton="Primary">

    <!-- Right-click on a tool button in the slim tools row opens this. Three knobs the user actually
         needs after install: rename the label, re-pick the runnable (in case the heuristic guessed
         wrong), and toggle EditsSaves to opt into the snapshot-before-launch path. Uninstall deletes
         the install folder AND removes the entry from tools.json; both paths are atomic. -->
    <StackPanel Spacing="12" Width="400">
        <TextBox Header="Display name" x:Name="DisplayNameBox" />
        <ComboBox Header="Runnable" x:Name="RunnableBox" HorizontalAlignment="Stretch" />
        <CheckBox Content="Edits saves (snapshot before launch)" x:Name="EditsSavesBox" />
        <HyperlinkButton Content="Open install folder" Click="OnOpenFolderClick" />
    </StackPanel>
</ContentDialog>
