<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="ModManager.App.Tools.ToolsPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="using:ModManager.Core.Tools"
    xmlns:fw="using:ModManager.Core.Frameworks"
    xmlns:vm="using:ModManager.App.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!-- Slim tools row, sits above the mod list. Three states share the same StackPanel:
         installed tools render as buttons, catalog entries that apply but aren't installed
         render as HyperlinkButton "Get …" chips, and an empty-state hint appears when both
         lists are empty. The + button is always present so the user can install ad-hoc tools. -->
    <Border BorderThickness="0,0,0,1"
            BorderBrush="{StaticResource ThemeBorder}"
            Background="{StaticResource ThemeBarBg}"
            Padding="12,6">
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">

            <TextBlock Text="TOOLS"
                       Foreground="{StaticResource ThemeInkSoft}"
                       FontSize="10"
                       CharacterSpacing="80"
                       VerticalAlignment="Center" />

            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Tools, Mode=OneWay}" VerticalAlignment="Center">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Horizontal" Spacing="6" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="core:ToolEntry">
                        <Button Padding="10,4"
                                Click="OnToolClick"
                                RightTapped="OnToolRightTapped"
                                Tag="{x:Bind}">
                            <ToolTipService.ToolTip>
                                <ToolTip>
                                    <TextBlock>
                                        <Run Text="{x:Bind DisplayName}" FontWeight="SemiBold" />
                                        <LineBreak/>
                                        <Run Text="Catalog metadata only — never bundled." />
                                        <LineBreak/>
                                        <Run Text="Click to launch." />
                                    </TextBlock>
                                </ToolTip>
                            </ToolTipService.ToolTip>
                            <TextBlock Text="{x:Bind DisplayName}" />
                        </Button>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <ItemsRepeater ItemsSource="{x:Bind ViewModel.MissingTools, Mode=OneWay}" VerticalAlignment="Center">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Horizontal" Spacing="6" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="core:KnownTool">
                        <HyperlinkButton Padding="10,4"
                                         Click="OnGetToolClick"
                                         Tag="{x:Bind}"
                                         ToolTipService.ToolTip="Open the download page in your browser">
                            <TextBlock Text="{x:Bind DisplayName}" />
                        </HyperlinkButton>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <!-- LOADERS section: detected launcher exes for ban-safe mod loaders (Mod Engine 2,
                 Seamless Co-op, …). Each button launches the loader directly so it can set up
                 the game's mod surface before handing off to the engine. Collapsed when none are
                 detected in the play folder. No #if FULL — on STORE, safe loaders are the
                 primary safe path since the EAC offline toggle is unavailable there. -->
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center"
                        Visibility="{x:Bind ViewModel.HasLoaders, Mode=OneWay}">
                <TextBlock Text="LOADERS"
                           Foreground="{StaticResource ThemeInkSoft}"
                           FontSize="10"
                           CharacterSpacing="80"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0" />
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.Loaders, Mode=OneWay}" VerticalAlignment="Center">
                    <ItemsRepeater.Layout>
                        <StackLayout Orientation="Horizontal" Spacing="6" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:DetectedLoaderRow">
                            <Button Padding="10,4"
                                    Click="OnLoaderClick"
                                    Tag="{x:Bind}">
                                <ToolTipService.ToolTip>
                                    <ToolTip>
                                        <TextBlock>
                                            <Run Text="{x:Bind DisplayName}" FontWeight="SemiBold" />
                                            <LineBreak/>
                                            <Run Text="Ban-safe mod loader — launches the game via its own entry point." />
                                            <LineBreak/>
                                            <Run Text="Click to launch." />
                                        </TextBlock>
                                    </ToolTip>
                                </ToolTipService.ToolTip>
                                <TextBlock>
                                    <Run Text="Launch via " />
                                    <Run Text="{x:Bind DisplayName}" />
                                </TextBlock>
                            </Button>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>

            <Button Padding="8,4"
                    Click="OnAddToolClick"
                    ToolTipService.ToolTip="Install a tool from a zip">
                <SymbolIcon Symbol="Add" />
            </Button>

            <TextBlock Text="No tools yet. Drop a zip to install, or click +."
                       VerticalAlignment="Center"
                       Foreground="{StaticResource ThemeInkSoft}"
                       Visibility="{x:Bind ViewModel.ToolsEmptyHintVisibility, Mode=OneWay}" />

            <!-- FRAMEWORKS section, same row as TOOLS. One button per installed framework; clicking it
                 pops a "how to use" toast read live from the framework's installed settings. The whole
                 section is collapsed when no framework is installed for the active game. -->
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center"
                        Visibility="{x:Bind ViewModel.HasInstalledFrameworks, Mode=OneWay}">
                <TextBlock Text="FRAMEWORKS"
                           Foreground="{StaticResource ThemeInkSoft}"
                           FontSize="10"
                           CharacterSpacing="80"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0" />
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.FrameworkRows, Mode=OneWay}" VerticalAlignment="Center">
                    <ItemsRepeater.Layout>
                        <StackLayout Orientation="Horizontal" Spacing="6" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:FrameworkRowViewModel">
                            <!-- A split affordance: the name opens the how-to toast; the pencil opens the
                                 framework's settings INI in the existing editor (snapshot-first). The pencil
                                 is collapsed when the framework installed no editable .ini. -->
                            <StackPanel Orientation="Horizontal" Spacing="2">
                                <Button Padding="10,4"
                                        Click="OnFrameworkClick"
                                        Tag="{x:Bind Manifest}"
                                        ToolTipService.ToolTip="How to use this — click for the in-game keys + mods folder">
                                    <TextBlock Text="{x:Bind DisplayName}" />
                                </Button>
                                <Button Padding="6,4"
                                        Click="OnEditFrameworkConfigClick"
                                        Tag="{x:Bind Manifest}"
                                        Visibility="{x:Bind ConfigVisibility}"
                                        ToolTipService.ToolTip="Edit this framework's settings (e.g. enable the UE4SS console)">
                                    <FontIcon Glyph="&#xE70F;" FontSize="12" />
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>

            <!-- The "how to use" toast: a TeachingTip whose title + body are filled in code
                 (OnFrameworkClick) from the live FrameworkUsage read. Lives in the panel (not laid
                 out) so a Border's single-child rule is respected; it anchors to the clicked button. -->
            <TeachingTip x:Name="UsageTip"
                         IsLightDismissEnabled="True"
                         PreferredPlacement="Bottom" />
        </StackPanel>
    </Border>
</UserControl>
