<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="ModManager.App.NewThemeDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="New theme"
    PrimaryButtonText="Import"
    CloseButtonText="Close"
    DefaultButton="Primary"
    PrimaryButtonClick="OnImport">

    <StackPanel Spacing="10" Width="460">
        <TextBlock TextWrapping="Wrap" Opacity="0.75" FontSize="12"
                   Text="Describe a vibe, copy the prompt into any AI chat, paste the JSON it returns below, then Import." />
        <TextBox x:Name="VibeBox" Header="Vibe" PlaceholderText="e.g. deep ocean bioluminescence" />
        <Button Content="Copy prompt" Click="OnCopyPrompt" />
        <TextBox x:Name="JsonBox" Header="Theme JSON" AcceptsReturn="True" Height="170" TextWrapping="Wrap"
                 PlaceholderText="Paste the JSON the AI returned" />
        <TextBlock x:Name="StatusText" Visibility="Collapsed" TextWrapping="Wrap" FontSize="12" />
    </StackPanel>
</ContentDialog>
