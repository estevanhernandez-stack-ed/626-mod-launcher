<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="ModManager.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Themeable palette — single brush instances mutated live by ThemeService.
                 Initialized to the default "626 Labs" theme (navy + cyan). -->
            <SolidColorBrush x:Key="ThemeBg" Color="#0F182B" />
            <SolidColorBrush x:Key="ThemeTitleBg" Color="#131A2A" />
            <SolidColorBrush x:Key="ThemeBarBg" Color="#1A2540" />
            <SolidColorBrush x:Key="ThemeFooterBg" Color="#0A121F" />
            <SolidColorBrush x:Key="ThemePanel" Color="#1A2540" />
            <SolidColorBrush x:Key="ThemeBorder" Color="#2A3A5C" />
            <SolidColorBrush x:Key="ThemeAccent" Color="#3BB4D9" />
            <SolidColorBrush x:Key="ThemeDanger" Color="#E13A5A" />
            <!-- Amber: conditional/optional hint (e.g. "MAY NEED") — de-escalated vs ThemeDanger's required red. -->
            <SolidColorBrush x:Key="ThemeWarning" Color="#E0A33A" />
            <SolidColorBrush x:Key="ThemeInk" Color="#E8F2FF" />
            <SolidColorBrush x:Key="ThemeInkSoft" Color="#A8C2D9" />

            <!-- ContentDialog + AccentButton overrides. Same-instance pattern as above so
                 ThemeService.Apply's in-place Color mutation flows through to every popup. The
                 keys here are the ones WinUI 3's default ContentDialog + AccentButton templates
                 look up - override them and every ContentDialog in the app picks up our theme. -->
            <SolidColorBrush x:Key="ContentDialogBackground" Color="#0F182B" />
            <SolidColorBrush x:Key="ContentDialogForeground" Color="#E8F2FF" />
            <SolidColorBrush x:Key="ContentDialogBorderBrush" Color="#2A3A5C" />
            <SolidColorBrush x:Key="ContentDialogTopOverlay" Color="#1A2540" />
            <SolidColorBrush x:Key="ContentDialogSeparatorBorderBrush" Color="#2A3A5C" />

            <SolidColorBrush x:Key="AccentButtonBackground" Color="#3BB4D9" />
            <SolidColorBrush x:Key="AccentButtonBackgroundPointerOver" Color="#3BB4D9" />
            <SolidColorBrush x:Key="AccentButtonBackgroundPressed" Color="#3BB4D9" />
            <SolidColorBrush x:Key="AccentButtonBackgroundDisabled" Color="#2A3A5C" />
            <SolidColorBrush x:Key="AccentButtonForeground" Color="#000000" />
            <SolidColorBrush x:Key="AccentButtonForegroundPointerOver" Color="#000000" />
            <SolidColorBrush x:Key="AccentButtonForegroundPressed" Color="#000000" />
            <SolidColorBrush x:Key="AccentButtonForegroundDisabled" Color="#A8C2D9" />

            <!-- ComboBox flyout (game picker + VIEW dropdown). Default WinUI uses near-black for the
                 popup chrome which doesn't match our navy. Override the dropdown chrome to ThemePanel
                 and route hover/selected accents through our brushes. -->
            <SolidColorBrush x:Key="ComboBoxDropDownBackground" Color="#1A2540" />
            <SolidColorBrush x:Key="ComboBoxDropDownBackgroundPointerOver" Color="#1A2540" />
            <SolidColorBrush x:Key="ComboBoxDropDownBackgroundPointerPressed" Color="#1A2540" />
            <SolidColorBrush x:Key="ComboBoxDropDownBorderBrush" Color="#2A3A5C" />
            <SolidColorBrush x:Key="ComboBoxDropDownForeground" Color="#E8F2FF" />
            <SolidColorBrush x:Key="ComboBoxItemBackgroundSelected" Color="#2A3A5C" />
            <SolidColorBrush x:Key="ComboBoxItemBackgroundSelectedPointerOver" Color="#2A3A5C" />
            <SolidColorBrush x:Key="ComboBoxItemBackgroundSelectedPressed" Color="#2A3A5C" />
            <SolidColorBrush x:Key="ComboBoxItemBackgroundPointerOver" Color="#2A3A5C" />
            <SolidColorBrush x:Key="ComboBoxItemForegroundSelected" Color="#E8F2FF" />
            <SolidColorBrush x:Key="ComboBoxItemForegroundSelectedPointerOver" Color="#E8F2FF" />
            <SolidColorBrush x:Key="ComboBoxItemForegroundPointerOver" Color="#E8F2FF" />

            <!-- MenuFlyout (THEME dropdown items, … More menu, per-row right-click menus). Same idea -
                 the default popup chrome is system-dark; align it to our navy. -->
            <SolidColorBrush x:Key="MenuFlyoutPresenterBackground" Color="#1A2540" />
            <SolidColorBrush x:Key="MenuFlyoutPresenterBorderBrush" Color="#2A3A5C" />
            <SolidColorBrush x:Key="MenuFlyoutItemForeground" Color="#E8F2FF" />
            <SolidColorBrush x:Key="MenuFlyoutItemBackgroundPointerOver" Color="#2A3A5C" />
            <SolidColorBrush x:Key="MenuFlyoutItemBackgroundPressed" Color="#2A3A5C" />
            <SolidColorBrush x:Key="MenuFlyoutItemForegroundPointerOver" Color="#E8F2FF" />
            <SolidColorBrush x:Key="MenuFlyoutItemForegroundPressed" Color="#E8F2FF" />
            <SolidColorBrush x:Key="MenuFlyoutSeparatorBackground" Color="#2A3A5C" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
