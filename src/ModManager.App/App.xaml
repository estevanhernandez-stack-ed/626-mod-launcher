<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="ModManager.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:ModManager.App.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <conv:BoolToVisibilityConverter x:Key="BoolToVis" />

            <!-- 626 brand accents (chrome). The in-app palette is themeable later. -->
            <SolidColorBrush x:Key="Accent626" Color="#17D4FA" />
            <SolidColorBrush x:Key="Magenta626" Color="#F22F89" />
            <SolidColorBrush x:Key="Hairline626" Color="#2A3A5C" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
