<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="ModManager.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Themeable palette — single brush instances mutated live by ThemeService.
                 Initialized to the default "626 Labs" theme (navy + cyan). -->
            <SolidColorBrush x:Key="ThemeBg" Color="#0F182B" />
            <SolidColorBrush x:Key="ThemeTitleBg" Color="#131A2A" />
            <SolidColorBrush x:Key="ThemeBarBg" Color="#1A2540" />
            <SolidColorBrush x:Key="ThemeFooterBg" Color="#0A121F" />
            <SolidColorBrush x:Key="ThemePanel" Color="#1A2540" />
            <SolidColorBrush x:Key="ThemeBorder" Color="#2A3A5C" />
            <SolidColorBrush x:Key="ThemeAccent" Color="#3BB4D9" />
            <SolidColorBrush x:Key="ThemeDanger" Color="#E13A5A" />
            <SolidColorBrush x:Key="ThemeInk" Color="#E8F2FF" />
            <SolidColorBrush x:Key="ThemeInkSoft" Color="#A8C2D9" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
