<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="ModManager.App.LooseIdentifyDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Identify loose mods on Nexus"
    CloseButtonText="Cancel" DefaultButton="Primary">
    <ScrollViewer MaxHeight="460" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="8" MinWidth="460">
            <TextBlock TextWrapping="Wrap" Opacity="0.8"
                       Text="Best Nexus name-search match per unidentified loose file. Check the rows to keep — nothing is saved until you hit Apply, and a later exact match (archive md5, manual URL) can still supersede a name match." />
            <ItemsControl x:Name="ProposalList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,2,0,2">
                            <CheckBox Visibility="{Binding MatchVisibility}"
                                      IsChecked="{Binding Approve, Mode=TwoWay}" Click="OnRowClick">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding Headline}" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding Detail}" TextWrapping="Wrap" Opacity="0.6"
                                               FontSize="12" Visibility="{Binding DetailVisibility}" />
                                </StackPanel>
                            </CheckBox>
                            <TextBlock Text="{Binding Headline}" Opacity="0.5" TextWrapping="Wrap"
                                       Visibility="{Binding NoMatchVisibility}" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</ContentDialog>
