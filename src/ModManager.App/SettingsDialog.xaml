<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="ModManager.App.SettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="using:ModManager.Core.Tools"
    xmlns:local="using:ModManager.App"
    Title="Settings"
    PrimaryButtonText="Apply"
    CloseButtonText="Close"
    DefaultButton="Primary"
    PrimaryButtonClick="OnApply">

    <ScrollViewer MaxHeight="640" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="14" Width="460">
            <!-- ============ IDENTITY ============ -->
            <TextBlock Text="Identity" FontWeight="SemiBold" FontSize="14" />
            <TextBlock TextWrapping="Wrap" Opacity="0.75" FontSize="12"
                       Text="Pick an image — a Discord avatar, a screenshot, a photo. Use it as the launcher's icon and derive a theme from its colors. Everything stays on your machine." />

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="96" Height="96" CornerRadius="8"
                        Background="{StaticResource ThemePanel}" BorderBrush="{StaticResource ThemeBorder}" BorderThickness="1">
                    <Image x:Name="PreviewImage" Stretch="UniformToFill" />
                </Border>
                <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                    <Button Content="Pick image…" Click="OnPickImage" />
                    <Button x:Name="RemoveButton" Content="Remove avatar" Click="OnRemove" Visibility="Collapsed" />
                    <TextBlock x:Name="FileLabel" Opacity="0.65" FontSize="11" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Grid>

            <TextBlock Text="Extracted palette" FontWeight="SemiBold" Margin="0,4,0,0" />
            <StackPanel x:Name="PaletteStrip" Orientation="Horizontal" Spacing="6" Height="32" />
            <TextBlock x:Name="PaletteEmpty" Text="Pick an image to see its dominant colors." Opacity="0.5" FontSize="12" />

            <CheckBox x:Name="UseAsIconCheck" Content="Use this image as the launcher's icon" IsChecked="True" />
            <CheckBox x:Name="DeriveThemeCheck" Content="Save a theme derived from these colors" IsChecked="True" />
            <TextBox x:Name="ThemeNameBox" Header="Theme name" Text="From avatar" />

            <!-- Window transparency. Sits with the icon options because both control how the
                 launcher LOOKS on the desktop. Applies immediately (no Apply button needed). -->
            <StackPanel Orientation="Vertical" Spacing="2" Margin="0,8,0,0">
                <TextBlock Text="Window transparency" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource ThemeInkSoft}" />
                <ComboBox x:Name="BackdropBox" SelectionChanged="OnBackdropChanged"
                          ToolTipService.ToolTip="Solid keeps the navy background. Mica lets a hint of the desktop tint show through. Acrylic is more translucent.">
                    <ComboBoxItem Content="Solid" Tag="solid" />
                    <ComboBoxItem Content="Mica (subtle)" Tag="mica" />
                    <ComboBoxItem Content="Acrylic (more translucent)" Tag="acrylic" />
                </ComboBox>
            </StackPanel>

            <!-- Divider -->
            <Border BorderBrush="{StaticResource ThemeBorder}" BorderThickness="0,1,0,0" Margin="0,8,0,0" />

            <!-- ============ NEXUS MODS ============ -->
            <TextBlock Text="Nexus Mods" FontWeight="SemiBold" FontSize="14" />

            <!-- Connected banner (visible when connected) -->
            <Border x:Name="NexusConnectedBanner" Visibility="Collapsed"
                    Background="{StaticResource ThemePanel}" BorderBrush="{StaticResource ThemeAccent}"
                    BorderThickness="0,0,0,2" Padding="12,10,12,10" CornerRadius="4">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE73E;" FontSize="18" Foreground="{StaticResource ThemeAccent}" VerticalAlignment="Center" />
                    <TextBlock x:Name="NexusConnectedText" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <TextBlock x:Name="NexusExplainer" TextWrapping="Wrap" Opacity="0.75" FontSize="12" />

            <PasswordBox x:Name="NexusKeyBox" />

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="NexusConnectButton" Content="Connect" Click="OnNexusConnect" />
                <Button x:Name="NexusDisconnectButton" Content="Disconnect" Click="OnNexusDisconnect" Visibility="Collapsed" />
            </StackPanel>

            <TextBlock x:Name="StatusText" Opacity="0.75" FontSize="12" TextWrapping="Wrap" />

            <!-- Auto-check toggle. Polls Nexus by mod id on game load (debounced ~24h/game) to flag
                 mods with a newer version available. The manual "Refresh Nexus stats" action works
                 regardless of this setting. -->
            <CheckBox x:Name="AutoCheckModUpdatesCheck"
                      Content="Check for mod updates automatically"
                      Click="OnAutoCheckModUpdatesToggled"
                      ToolTipService.ToolTip="On game load, quietly check Nexus for newer versions of your installed mods (about once a day per game). The manual Refresh Nexus stats action always works." />

            <!-- Keep-plugins-updated toggle. Gates the 24h re-check of the plugin feed (the first
                 install on Nexus connect always fires regardless). Desktop (FULL) only — the STORE
                 build shows a static note because plugins are a desktop-only delivery channel. -->
            <CheckBox x:Name="KeepPluginsUpdatedCheck"
                      Content="Keep plugins updated"
                      Click="OnKeepPluginsUpdatedToggled"
                      ToolTipService.ToolTip="Once a day, quietly fetch the latest signed Nexus plugin from the 626 Mod Launcher feed. The first install always runs on connect; this gates the daily re-check." />
            <TextBlock x:Name="PluginStatusText" Opacity="0.65" FontSize="12" />

            <!-- Divider -->
            <Border BorderBrush="{StaticResource ThemeBorder}" BorderThickness="0,1,0,0" Margin="0,8,0,0" />

            <!-- ============ ABOUT ============ -->
            <TextBlock Text="About" FontWeight="SemiBold" FontSize="14" />
            <TextBlock TextWrapping="Wrap" Opacity="0.75" FontSize="12" Margin="0,8,0,0">
                <Run Text="Save editor format work based on community reverse-engineering. Credit to: " />
                <Hyperlink NavigateUri="https://github.com/BenGrn/EldenRingSaveCopier">
                    <Run Text="BenGrn/EldenRingSaveCopier" />
                </Hyperlink>
                <Run Text=" (MIT), " />
                <Hyperlink NavigateUri="https://github.com/ClayAmore/ER-Save-Editor">
                    <Run Text="ClayAmore/ER-Save-Editor" />
                </Hyperlink>
                <Run Text=" (Apache-2.0), " />
                <Hyperlink NavigateUri="https://github.com/alfizari/Elden-Ring-Save-Editor">
                    <Run Text="alfizari/Elden-Ring-Save-Editor" />
                </Hyperlink>
                <Run Text=" (MIT). Full license texts in THIRD_PARTY_NOTICES.md." />
            </TextBlock>

            <TextBlock Text="Installed tools" FontWeight="SemiBold" Margin="0,16,0,4" />
            <TextBlock x:Name="InstalledToolsEmpty" Text="No third-party tools installed yet."
                       Opacity="0.55" FontSize="12" Visibility="Collapsed" />
            <ItemsRepeater x:Name="InstalledToolsList">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Vertical" Spacing="8" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="core:ToolEntry">
                        <StackPanel>
                            <TextBlock Text="{x:Bind DisplayName}" FontWeight="SemiBold" />
                            <TextBlock Text="Catalog metadata only — never bundled. See NOTICE for full attribution."
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       FontSize="12" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <TextBlock Text="Installed frameworks" FontWeight="SemiBold" Margin="0,16,0,4" />
            <TextBlock x:Name="InstalledFrameworksEmpty" Text="No frameworks installed by the launcher yet."
                       Opacity="0.55" FontSize="12" Visibility="Collapsed" />
            <ItemsRepeater x:Name="InstalledFrameworksList">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Vertical" Spacing="8" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="local:InstalledFrameworkRow">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind DisplayName}" FontWeight="SemiBold" />
                                <TextBlock Text="{x:Bind Detail}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           FontSize="12" TextWrapping="Wrap" />
                            </StackPanel>
                            <HyperlinkButton Grid.Column="1" Content="Get it here" NavigateUri="{x:Bind GetUriObj}"
                                             Opacity="0.75" FontSize="12" VerticalAlignment="Center" />
                            <Button Grid.Column="2" Content="Uninstall" Tag="{x:Bind FrameworkId}"
                                    Click="OnUninstallFramework" VerticalAlignment="Center" />
                        </Grid>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
            <TextBlock Opacity="0.5" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"
                       Text="The launcher never bundles frameworks. Drop a recognized framework zip to install; this section tracks what's been installed and reverses it." />

            <TextBlock Text="Direct-inject mod configs" FontWeight="SemiBold" Margin="0,16,0,4" />

            <TextBlock Opacity="0.55" FontSize="12" TextWrapping="Wrap"
                       Text="Per-mod config-file path overrides for direct-inject mods (Seamless Co-op, ReShade, etc.). Leave alone to use the catalog default; Override when your install is in an unusual location." />
            <ItemsRepeater x:Name="DirectInjectConfigsList">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Vertical" Spacing="8" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="local:DirectInjectConfigRow">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold" />
                                <TextBlock Text="{x:Bind Subtitle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           FontSize="12" TextWrapping="Wrap" />
                            </StackPanel>
                            <Button Grid.Column="1" Content="Override…" Tag="{x:Bind}"
                                    Click="OnDirectInjectOverrideClick" VerticalAlignment="Center" />
                        </Grid>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
            <TextBlock x:Name="DirectInjectConfigsEmpty"
                       Text="No catalog-known direct-inject mods for the active engine."
                       Opacity="0.55" FontSize="12" Visibility="Collapsed" />

            <!-- Divider -->
            <Border BorderBrush="{StaticResource ThemeBorder}" BorderThickness="0,1,0,0" Margin="0,8,0,0" />

            <!-- ============ RESET ============ -->
            <TextBlock Text="Reset" FontWeight="SemiBold" FontSize="14" />
            <TextBlock TextWrapping="Wrap" Opacity="0.75" FontSize="12"
                       Text="Archive your current setup to a restore point, then reset the launcher to first-run. Your mods stay on disk." />
            <Button x:Name="ResetLauncherButton"
                    Content="Reset launcher…"
                    Click="OnResetLauncher" />

            <!-- Divider -->
            <Border BorderBrush="{StaticResource ThemeBorder}" BorderThickness="0,1,0,0" Margin="0,8,0,0" />

            <!-- ============ RESTORE POINTS ============ -->
            <TextBlock Text="Restore points" FontWeight="SemiBold" FontSize="14" />
            <TextBlock TextWrapping="Wrap" Opacity="0.75" FontSize="12"
                       Text="Snapshots of your launcher state created before a reset. Restore to bring back a previous setup, or delete what you no longer need." />
            <TextBlock x:Name="NoRestorePointsText" Text="No restore points yet."
                       Opacity="0.55" FontSize="12" Visibility="Collapsed" />
            <ItemsRepeater x:Name="RestorePointsList">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Vertical" Spacing="8" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="local:RestorePointRow">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind Timestamp}" FontWeight="SemiBold" />
                                <TextBlock Text="{x:Bind Detail}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           FontSize="12" TextWrapping="Wrap" />
                            </StackPanel>
                            <Button Grid.Column="1" Content="Restore" Tag="{x:Bind Id}"
                                    Click="OnRestorePoint" VerticalAlignment="Center" />
                            <Button Grid.Column="2" Content="Delete" Tag="{x:Bind Id}"
                                    Click="OnDeleteRestorePoint" VerticalAlignment="Center" />
                        </Grid>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </StackPanel>
    </ScrollViewer>
</ContentDialog>
