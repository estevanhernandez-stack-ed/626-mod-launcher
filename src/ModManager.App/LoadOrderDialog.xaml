<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="ModManager.App.LoadOrderDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Load order"
    CloseButtonText="Close"
    DefaultButton="Close">

    <StackPanel Spacing="12" Width="480">
        <TextBlock TextWrapping="Wrap" Opacity="0.75" FontSize="12"
                   Text="Top loads first. Apply prefixes your pak files (0010__, 0020__ …) so the game loads them in this order — it's reversible with Reset." />
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ListView x:Name="OrderList" Grid.Column="0" MaxHeight="320" SelectionMode="Single" />
            <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Top" Margin="8,0,0,0">
                <Button Content="&#xE74A;" FontFamily="Segoe Fluent Icons" Click="OnUp" ToolTipService.ToolTip="Move up" />
                <Button Content="&#xE74B;" FontFamily="Segoe Fluent Icons" Click="OnDown" ToolTipService.ToolTip="Move down" />
            </StackPanel>
        </Grid>
        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Apply order" Click="OnApply" />
            <Button Content="Reset" Click="OnReset" />
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Opacity="0.75" FontSize="12" TextWrapping="Wrap" />
        </StackPanel>
    </StackPanel>
</ContentDialog>
