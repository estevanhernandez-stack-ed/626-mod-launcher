<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ModManager.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:ModManager.App.ViewModels"
    xmlns:shapes="using:Microsoft.UI.Xaml.Shapes"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid AllowDrop="True" DragOver="OnDragOver" Drop="OnDrop"
          RequestedTheme="Dark" Background="{StaticResource ThemeBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title bar (custom, draggable). Last column reserves the caption-button inset so the
             interactive controls never sit under the system min/max/close buttons. -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="48" Padding="12,0" ColumnSpacing="12"
              Background="{StaticResource ThemeTitleBg}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="140" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Border Width="14" Height="14" Background="{StaticResource ThemeAccent}" CornerRadius="3" />
                <TextBlock Text="626 Mod Launcher" FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center"
                        Visibility="{x:Bind ViewModel.GameVisibility, Mode=OneWay}">
                <ComboBox MinWidth="180"
                          ItemsSource="{x:Bind ViewModel.Games, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.ActiveGame, Mode=TwoWay}"
                          DisplayMemberPath="Name" />
                <Button ToolTipService.ToolTip="Game options" Background="Transparent" BorderThickness="0">
                    <FontIcon Glyph="&#xE712;" FontSize="14" />
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="Find mods on Nexus Mods" Tag="nexus" Click="OnFindMods">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE721;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem Text="Find mods on CurseForge" Tag="curseforge" Click="OnFindMods">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE721;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutSeparator />
                            <MenuFlyoutItem Text="Backfill metadata from Nexus archives…" Click="OnNexusBackfill"
                                            ToolTipService.ToolTip="Point at your folder of downloaded Nexus .zip archives to fill metadata for installed mods">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE896;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem Text="Re-scan mods &amp; launchers" Click="OnRedetect">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE72C;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutSeparator />
                            <MenuFlyoutItem Text="Fetch metadata for all mods" Command="{x:Bind ViewModel.FetchMetadataCommand}"
                                            ToolTipService.ToolTip="Re-fetch metadata from CurseForge for every mod (best-effort).">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE8F1;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem Text="Generate a theme with AI…" Click="OnNewTheme"
                                            ToolTipService.ToolTip="Use AI to generate a custom color theme — installs instantly.">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE790;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutSeparator />
                            <MenuFlyoutItem Text="Remove this game…" Click="OnRemoveGame">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE74D;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
            </StackPanel>
            <Button Grid.Column="3" Content="+ Game" VerticalAlignment="Center" Click="OnAddGame" />
            <SplitButton Grid.Column="4" Content="▶ Launch" VerticalAlignment="Center"
                         Command="{x:Bind ViewModel.LaunchCommand}"
                         ToolTipService.ToolTip="Launch the default target — open the menu for vanilla / modded / alt launchers"
                         Foreground="Black" Background="{StaticResource ThemeAccent}">
                <SplitButton.Flyout>
                    <MenuFlyout Placement="Bottom" Opening="OnLaunchMenuOpening" />
                </SplitButton.Flyout>
            </SplitButton>
        </Grid>

        <!-- Command bar -->
        <Grid Grid.Row="1" Padding="12,6" Background="{StaticResource ThemeBarBg}"
              BorderBrush="{StaticResource ThemeBorder}" BorderThickness="0,1,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0" Visibility="{x:Bind ViewModel.NormalBarVisibility, Mode=OneWay}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <!-- Row 0: group labels -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6" Margin="0,0,0,2">
                    <TextBlock Text="LIST"     Width="68"  Foreground="{StaticResource ThemeInkSoft}" FontSize="10" CharacterSpacing="80" />
                    <TextBlock Text="TOGGLE"   Width="160" Foreground="{StaticResource ThemeInkSoft}" FontSize="10" CharacterSpacing="80" Margin="6,0,0,0" />
                    <TextBlock Text="LOADOUT"  Width="148" Foreground="{StaticResource ThemeInkSoft}" FontSize="10" CharacterSpacing="80" Margin="6,0,0,0" />
                    <TextBlock Text="MODS"     Width="100" Foreground="{StaticResource ThemeInkSoft}" FontSize="10" CharacterSpacing="80" Margin="6,0,0,0" />
                    <TextBlock Text="LIBRARY"  Foreground="{StaticResource ThemeInkSoft}" FontSize="10" CharacterSpacing="80" Margin="6,0,0,0" />
                </StackPanel>
                <!-- Row 1: controls (relabeled) -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6">
                    <Button Content="↻ Rescan" Command="{x:Bind ViewModel.RefreshCommand}"
                            ToolTipService.ToolTip="Re-scan the game folder for new or removed mods" />
                    <shapes:Rectangle Width="1" Fill="{StaticResource ThemeBorder}" Margin="4,6" />
                    <Button Content="Enable all" Command="{x:Bind ViewModel.AllOnCommand}" />
                    <Button Content="Disable all" Command="{x:Bind ViewModel.AllOffCommand}" />
                    <shapes:Rectangle Width="1" Fill="{StaticResource ThemeBorder}" Margin="4,6" />
                    <Border CornerRadius="3" BorderThickness="1" BorderBrush="{StaticResource ThemeBorder}"
                            Background="{StaticResource ThemePanel}">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="All" Command="{x:Bind ViewModel.SetModeCommand}" CommandParameter="all"
                                    BorderThickness="0" CornerRadius="0" MinWidth="44"
                                    Background="{x:Bind ViewModel.LoadoutAllBrush, Mode=OneWay}"
                                    Foreground="{x:Bind ViewModel.LoadoutAllForeground, Mode=OneWay}" />
                            <shapes:Rectangle Width="1" Fill="{StaticResource ThemeBorder}" />
                            <Button Content="MP"  Command="{x:Bind ViewModel.SetModeCommand}" CommandParameter="mp"
                                    BorderThickness="0" CornerRadius="0" MinWidth="44"
                                    Background="{x:Bind ViewModel.LoadoutMpBrush, Mode=OneWay}"
                                    Foreground="{x:Bind ViewModel.LoadoutMpForeground, Mode=OneWay}" />
                            <shapes:Rectangle Width="1" Fill="{StaticResource ThemeBorder}" />
                            <Button Content="SP"  Command="{x:Bind ViewModel.SetModeCommand}" CommandParameter="sp"
                                    BorderThickness="0" CornerRadius="0" MinWidth="44"
                                    Background="{x:Bind ViewModel.LoadoutSpBrush, Mode=OneWay}"
                                    Foreground="{x:Bind ViewModel.LoadoutSpForeground, Mode=OneWay}" />
                        </StackPanel>
                    </Border>
                    <shapes:Rectangle Width="1" Fill="{StaticResource ThemeBorder}" Margin="4,6" />
                    <Button Content="+ Add mods" Click="OnAddMods" />
                    <shapes:Rectangle Width="1" Fill="{StaticResource ThemeBorder}" Margin="4,6" />
                    <Button Content="Reorder" Click="OnUnlockLoadOrder" ToolTipService.ToolTip="Drag rows to set the load order" />
                    <Button Content="Profiles" Click="OnProfiles" ToolTipService.ToolTip="Saved loadouts" />
                    <Button Content="Saves" Click="OnSaves" ToolTipService.ToolTip="Save snapshots + installed save mods" />
                    <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" Width="18" Height="18" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>

            <!-- Load-order mode: reorder controls replace the normal bar -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center"
                        Visibility="{x:Bind ViewModel.LoadOrderVisibility, Mode=OneWay}">
                <FontIcon Glyph="&#xE8CB;" FontSize="14" Foreground="{StaticResource ThemeAccent}" />
                <TextBlock Text="Load order — drag rows or type a position." VerticalAlignment="Center" />
                <Button Content="Apply order" Click="OnApplyOrder" Foreground="Black" Background="{StaticResource ThemeAccent}" />
                <Button Content="Cancel" Click="OnCancelOrder" />
            </StackPanel>
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <!-- Row 0: group labels -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6" Margin="0,0,0,2" HorizontalAlignment="Right">
                    <TextBlock Text="VIEW"    Width="248" Foreground="{StaticResource ThemeInkSoft}" FontSize="10" CharacterSpacing="80" TextAlignment="Right" />
                    <TextBlock Text="ACCOUNT" Width="80"  Foreground="{StaticResource ThemeInkSoft}" FontSize="10" CharacterSpacing="80" TextAlignment="Right" Margin="6,0,0,0" />
                </StackPanel>
                <!-- Row 1: informational widgets + view/account controls -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Button Click="OnCoopHint" Background="Transparent" BorderThickness="0"
                            ToolTipService.ToolTip="Seamless Co-op is installed but its launcher is missing — co-op needs the full mod"
                            Visibility="{x:Bind ViewModel.CoopHintVisibility, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon Glyph="&#xE7BA;" FontSize="13" Foreground="{StaticResource ThemeDanger}" />
                            <TextBlock Text="Co-op needs its launcher" Foreground="{StaticResource ThemeDanger}" />
                        </StackPanel>
                    </Button>
                    <Border Padding="8,2" CornerRadius="4"
                            ToolTipService.ToolTip="Some enabled mods may desync co-op — review before hosting or joining"
                            Visibility="{x:Bind ViewModel.MpWarningVisibility, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE7BA;" FontSize="13" Foreground="{StaticResource ThemeDanger}" />
                            <TextBlock Text="{x:Bind ViewModel.MpWarningText, Mode=OneWay}"
                                       Foreground="{StaticResource ThemeDanger}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Button Click="OnLaunchOptions" Foreground="Black" Background="{StaticResource ThemeAccent}"
                            ToolTipService.ToolTip="This game needs a launch option for mods to load"
                            Visibility="{x:Bind ViewModel.LaunchHintVisibility, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE7BA;" FontSize="13" />
                            <TextBlock Text="Launch options" />
                        </StackPanel>
                    </Button>
                    <ComboBox MinWidth="120" ToolTipService.ToolTip="Group the mod list"
                              ItemsSource="{x:Bind ViewModel.GroupModes}"
                              SelectedItem="{x:Bind ViewModel.GroupMode, Mode=TwoWay}" />
                    <ComboBox MinWidth="120" ToolTipService.ToolTip="Theme"
                              ItemsSource="{x:Bind ViewModel.ThemeOptions, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedTheme, Mode=TwoWay}"
                              DisplayMemberPath="Name" />
                    <shapes:Rectangle Width="1" Fill="{StaticResource ThemeBorder}" Margin="4,6" />
                    <Button Content="Nexus" Click="OnNexus" ToolTipService.ToolTip="Connect your Nexus Mods account (per-user API key) for metadata + md5 mod ID" />
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Mod list -->
        <ListView Grid.Row="2" Padding="8,4"
                  ItemsSource="{x:Bind ViewModel.Mods, Mode=OneWay}" SelectionMode="None"
                  CanReorderItems="{x:Bind ViewModel.IsLoadOrderMode, Mode=OneWay}"
                  CanDragItems="{x:Bind ViewModel.IsLoadOrderMode, Mode=OneWay}"
                  AllowDrop="{x:Bind ViewModel.IsLoadOrderMode, Mode=OneWay}"
                  DragItemsCompleted="OnReorderCompleted"
                  Visibility="{x:Bind ViewModel.GameVisibility, Mode=OneWay}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:ModRowViewModel">
                    <StackPanel>
                    <TextBlock Text="{x:Bind SectionHeader}" Visibility="{x:Bind SectionHeaderVisibility, Mode=OneWay}"
                               FontWeight="SemiBold" FontSize="12" CharacterSpacing="80"
                               Foreground="{StaticResource ThemeAccent}" Margin="4,16,0,4" />
                    <Grid Padding="4,8" ColumnSpacing="12" BorderBrush="{StaticResource ThemeBorder}" BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Icon cell: load-order number (editable) in reorder mode, else art/monogram -->
                        <Grid Grid.Column="0" Width="48" Height="40" VerticalAlignment="Center">
                            <Border Background="{StaticResource ThemePanel}" CornerRadius="6"
                                    Visibility="{x:Bind MonogramVisibility, Mode=OneWay}">
                                <TextBlock Text="{x:Bind Initial}" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{StaticResource ThemeAccent}" />
                            </Border>
                            <Border CornerRadius="6" Visibility="{x:Bind ThumbnailVisibility, Mode=OneWay}">
                                <Image Source="{x:Bind Thumbnail}" Stretch="UniformToFill" />
                            </Border>
                            <NumberBox Value="{x:Bind OrderValue, Mode=OneWay}" ValueChanged="OnJump"
                                       SpinButtonPlacementMode="Hidden" VerticalAlignment="Center" Width="48"
                                       Visibility="{x:Bind OrderVisibility, Mode=OneWay}" />
                        </Grid>

                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{x:Bind DisplayName}" FontWeight="SemiBold" FontSize="15" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{x:Bind FileTag}" FontFamily="Consolas" FontSize="11" Opacity="0.45"
                                           VerticalAlignment="Center" Visibility="{x:Bind FileTagVisibility}" />
                            </StackPanel>
                            <TextBlock Text="{x:Bind Description}" Opacity="0.7" TextWrapping="Wrap" MaxLines="2"
                                       Visibility="{x:Bind DescriptionVisibility}" />
                            <StackPanel Orientation="Horizontal" Spacing="2" Visibility="{x:Bind CreditVisibility}">
                                <TextBlock Text="{x:Bind AuthorText}" Opacity="0.55" FontSize="12" VerticalAlignment="Center"
                                           Visibility="{x:Bind AuthorVisibility}" />
                                <HyperlinkButton Content="{x:Bind ModUrlLabel}" NavigateUri="{x:Bind ModUri}" Padding="6,0" FontSize="12"
                                                 Visibility="{x:Bind ModUrlVisibility}" />
                                <HyperlinkButton Content="Source" NavigateUri="{x:Bind SourceUri}" Padding="6,0" FontSize="12"
                                                 Visibility="{x:Bind SourceVisibility}" />
                                <HyperlinkButton Content="Donate" NavigateUri="{x:Bind DonateUri}" Padding="6,0" FontSize="12"
                                                 Foreground="{StaticResource ThemeDanger}" Visibility="{x:Bind DonateVisibility}" />
                                <TextBlock Text="{x:Bind DownloadsText}" Opacity="0.55" FontSize="12" VerticalAlignment="Center"
                                           Visibility="{x:Bind DownloadsVisibility}" />
                            </StackPanel>
                            <!-- Multi-variant family: pick which level(s) to run, inline on this one row -->
                            <ItemsControl ItemsSource="{x:Bind VariantOptions}" Margin="0,4,0,0"
                                          Visibility="{x:Bind VariantOptionsVisibility, Mode=OneWay}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="6" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:VariantOptionVM">
                                        <ToggleButton Content="{x:Bind Label}" IsChecked="{x:Bind Enabled, Mode=OneWay}"
                                                      IsEnabled="{x:Bind CanToggle}" Click="OnVariantClick"
                                                      MinWidth="0" Padding="10,2" FontSize="12" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="Same mod, different levels — pick one (turning one on turns the others off). Drop in more anytime; they won't collide."
                                       Opacity="0.5" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"
                                       Visibility="{x:Bind VariantOptionsVisibility, Mode=OneWay}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Border CornerRadius="3" Padding="6,2" Background="{StaticResource ThemePanel}"
                                    BorderThickness="1" BorderBrush="{StaticResource ThemeInkSoft}"
                                    ToolTipService.ToolTip="Managed by another mod tool — shown read-only here"
                                    Visibility="{x:Bind ManagedVisibility, Mode=OneWay}">
                                <TextBlock Text="{x:Bind ManagedBadge}" FontFamily="Consolas" FontSize="11" Opacity="0.8" />
                            </Border>
                            <Border CornerRadius="3" Padding="6,2" Background="{StaticResource ThemePanel}"
                                    BorderThickness="1" BorderBrush="{StaticResource ThemeInkSoft}"
                                    ToolTipService.ToolTip="Ships with UE4SS — framework mod, not a downloaded mod"
                                    Visibility="{x:Bind BuiltinVisibility, Mode=OneWay}">
                                <TextBlock Text="UE4SS BUILT-IN" FontFamily="Consolas" FontSize="11" Opacity="0.7" />
                            </Border>
                            <Border CornerRadius="3" Padding="6,2" Background="{StaticResource ThemeAccent}"
                                    ToolTipService.ToolTip="One of several variants of the same mod — toggle whichever you want"
                                    Visibility="{x:Bind VariantGroupVisibility, Mode=OneWay}">
                                <TextBlock Text="VARIANT" FontFamily="Consolas" FontSize="11" Foreground="Black" />
                            </Border>
                            <Border Background="{StaticResource ThemePanel}" CornerRadius="3" Padding="6,2">
                                <TextBlock Text="{x:Bind ClassChip}" FontFamily="Consolas" FontSize="11" />
                            </Border>
                            <Border Background="{StaticResource ThemePanel}" CornerRadius="3" Padding="6,2"
                                    Visibility="{x:Bind VariantVisibility}">
                                <TextBlock Text="{x:Bind VariantChip}" FontFamily="Consolas" FontSize="11" />
                            </Border>
                            <!-- MP-safety badge doubles as the set-override affordance (faint "MP?" = no claim) -->
                            <Button Padding="6,2" CornerRadius="3" BorderThickness="0"
                                    Background="{StaticResource ThemePanel}" VerticalAlignment="Center"
                                    Opacity="{x:Bind MpBadgeOpacity, Mode=OneWay}"
                                    ToolTipService.ToolTip="Multiplayer safety — click to set">
                                <TextBlock Text="{x:Bind MpBadge, Mode=OneWay}" FontFamily="Consolas" FontSize="11"
                                           Foreground="{x:Bind MpBadgeBrush, Mode=OneWay}" />
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Mark MP-safe" Click="OnSetMpCompat" Tag="Safe" />
                                        <MenuFlyoutItem Text="Mark MP-risky" Click="OnSetMpCompat" Tag="Risky" />
                                        <MenuFlyoutItem Text="Mark SP-only" Click="OnSetMpCompat" Tag="SpOnly" />
                                        <MenuFlyoutItem Text="Auto (clear)" Click="OnSetMpCompat" Tag="Auto" />
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>
                        </StackPanel>

                        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                            <Button Click="OnShowReadme" VerticalAlignment="Center"
                                    Background="Transparent" BorderThickness="0"
                                    ToolTipService.ToolTip="Readme"
                                    Visibility="{x:Bind ReadmeVisibility, Mode=OneWay}">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Spacing="0">
                                    <FontIcon Glyph="&#xE8A5;" FontSize="14" HorizontalAlignment="Center" />
                                    <TextBlock Text="readme" FontSize="9" Foreground="{StaticResource ThemeInkSoft}" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Click="OnShowCockpit" VerticalAlignment="Center"
                                    Background="Transparent" BorderThickness="0"
                                    ToolTipService.ToolTip="Config cockpit — edit settings, view keybinds &amp; commands"
                                    Visibility="{x:Bind CockpitVisibility, Mode=OneWay}">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Spacing="0">
                                    <FontIcon Glyph="&#xE713;" FontSize="14" HorizontalAlignment="Center" />
                                    <TextBlock Text="config" FontSize="9" Foreground="{StaticResource ThemeInkSoft}" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <ToggleSwitch Grid.Column="4" IsOn="{x:Bind Enabled, Mode=OneWay}" Toggled="OnModToggled"
                                      IsEnabled="{x:Bind CanToggle}"
                                      VerticalAlignment="Center" MinWidth="0" OnContent="" OffContent=""
                                      Visibility="{x:Bind ToggleVisibility, Mode=OneWay}" />

                        <Button Grid.Column="5" Click="OnUninstall" VerticalAlignment="Center"
                                Background="Transparent" BorderThickness="0"
                                ToolTipService.ToolTip="Uninstall (permanent)"
                                Visibility="{x:Bind ManageVisibility, Mode=OneWay}">
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Spacing="0">
                                <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="{StaticResource ThemeDanger}" HorizontalAlignment="Center" />
                                <TextBlock Text="uninstall" FontSize="9" Foreground="{StaticResource ThemeInkSoft}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Empty state -->
        <TextBlock Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.6"
                   Text="No game registered yet. Add one with + Game."
                   Visibility="{x:Bind ViewModel.EmptyVisibility, Mode=OneWay}" />

        <!-- Status bar -->
        <Grid Grid.Row="3" Height="32" Padding="12,0" Background="{StaticResource ThemeFooterBg}"
              BorderBrush="{StaticResource ThemeBorder}" BorderThickness="0,1,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{x:Bind ViewModel.GameRootText, Mode=OneWay}" Opacity="0.5" FontSize="12"
                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
            <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" Opacity="0.8" FontSize="12"
                       VerticalAlignment="Center" />
        </Grid>
    </Grid>
</Window>
